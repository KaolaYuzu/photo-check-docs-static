{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PhotoCheck Docs V2.8 — Normalized Document JSON",
  "description": "Unified intermediate format from all provider adapters. _noRetain:true means this object must never be persisted.",
  "type": "object",
  "properties": {
    "version":              { "type": "string", "const": "v2.8" },
    "documentType":         { "type": "string", "enum": ["simple-table","structured-form","document","unknown"] },
    "riskLevel":            { "type": "string", "enum": ["standard","elevated","high"] },
    "extractionStrategy":   { "type": "string", "enum": ["excel","form","doc","unknown"] },
    "confidence":           { "type": "number", "minimum": 0, "maximum": 1 },
    "providerMeta": {
      "type": "object",
      "properties": {
        "name":           { "type": "string", "examples": ["google-document-ai","azure-document-intelligence","aws-textract","legacy-canvas-grid","mock"] },
        "processingTime": { "type": "number", "description": "milliseconds" },
        "ocrEngine":      { "type": "string" }
      }
    },
    "blocks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id":           { "type": "string" },
          "blockType":    { "type": "string", "enum": ["table","kv-pair","paragraph","heading","list","unknown"] },
          "confidence":   { "type": "number", "minimum": 0, "maximum": 1 },
          "bbox":         { "type": ["object","null"], "properties": { "x":{}, "y":{}, "w":{}, "h":{} } },
          "readingOrder": { "type": "integer" },
          "content": {
            "type": "object",
            "properties": {
              "text":  { "type": "string", "description": "paragraph / heading / list content" },
              "key":   { "type": "string", "description": "kv-pair key" },
              "value": { "type": "string", "description": "kv-pair value" },
              "rows":  { "type": "array", "description": "table rows", "items": { "type": "object", "properties": { "cells": { "type": "array" } } } }
            }
          }
        }
      }
    },
    "tables":     { "type": "array", "description": "References to blocks where blockType=table" },
    "forms":      { "type": "array", "description": "References to blocks where blockType=kv-pair" },
    "paragraphs": { "type": "array", "description": "References to blocks where blockType=paragraph|heading|list" },
    "meta": {
      "type": "object",
      "properties": {
        "createdAt":        { "type": "string", "format": "date-time" },
        "processingNotes":  { "type": "array" },
        "_debug":           { "type": "object" },
        "_noRetain":        { "type": "boolean", "const": true, "description": "This object must NEVER be persisted to disk, database, or external service." }
      }
    }
  },
  "required": ["version","documentType","riskLevel","extractionStrategy","confidence","providerMeta","blocks","meta"]
}
